{
  "family": "fitscript-ops-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::251522454901:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::251522454901:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "fitscript-ops-container",
      "image": "251522454901.dkr.ecr.us-east-1.amazonaws.com/fitscript-ops:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "5001" },
        { "name": "OPS_PORT", "value": "5001" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:251522454901:secret:prod/ops-secrets-j5vKKG:DATABASE_URL::"
        },
        {
          "name": "STRIPE_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:251522454901:secret:prod/ops-secrets-j5vKKG:STRIPE_SECRET_KEY::"
        },
        {
          "name": "GOOGLE_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:251522454901:secret:prod/ops-secrets-j5vKKG:GOOGLE_CLIENT_ID::"
        },
        {
          "name": "GOOGLE_CLIENT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:251522454901:secret:prod/ops-secrets-j5vKKG:GOOGLE_CLIENT_SECRET::"
        },
        {
          "name": "OPS_GOOGLE_REDIRECT_URI",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:251522454901:secret:prod/ops-secrets-j5vKKG:OPS_GOOGLE_REDIRECT_URI::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/fitscript-ops",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "node -e \"require('http').get('http://localhost:5001/api/health', r => process.exit(r.statusCode === 200 ? 0 : 1))\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}